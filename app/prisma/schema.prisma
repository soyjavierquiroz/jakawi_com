generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AnalyticsEventType {
  STORE_VIEW
  PRODUCT_VIEW
  WHATSAPP_CLICK
}

enum LeadStatus {
  BROWSING
  ENGAGED
  WHATSAPP_CLICKED
  CONTACTED
  WON
  LOST
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum LeadEventType {
  STORE_VIEW
  PRODUCT_VIEW
  CATEGORY_VIEW
  CHAT_OPENED
  AI_MESSAGE_SENT
  CUSTOMER_MESSAGE_SENT
  PRODUCT_RECOMMENDED
  WHATSAPP_CLICKED
  LEAD_CREATED
  LEAD_UPDATED
  LEAD_STATUS_CHANGED
}

enum CustomerJourneyStatus {
  ACTIVE
  ENGAGED
  READY_FOR_CHANNEL
  CHANNEL_CONNECTED
  CONVERTED
  LOST
  EXPIRED
}

enum CustomerJourneyStage {
  DISCOVERY
  PRODUCT_ADVISOR
  DECISION_SUPPORT
  CLOSING_PREP
}

enum JourneyEventType {
  JOURNEY_STARTED
  STORE_VIEWED
  CATEGORY_VIEWED
  PRODUCT_VIEWED
  SELLER_AI_OPENED
  AI_MESSAGE_SENT
  CUSTOMER_MESSAGE_SENT
  NEED_DETECTED
  PRODUCT_RECOMMENDED
  OBJECTION_DETECTED
  INTENT_UPDATED
  LEAD_CREATED
  SNAPSHOT_CREATED
  CHANNEL_CLICKED
  STATUS_CHANGED
}

enum CommercialSnapshotChannel {
  WHATSAPP
  WHATSAPP_BOT
  EMAIL
  INSTAGRAM
  MESSENGER
  MANUAL
}

enum AuthTokenType {
  PASSWORD_RESET
  EMAIL_VERIFY
}

model User {
  id              String    @id @default(cuid())
  name            String
  firstName       String?
  lastName        String?
  email           String    @unique
  passwordHash    String
  emailVerifiedAt DateTime?
  phone           String?
  countryCode     String?
  countryName     String?
  currency        String?
  role            String    @default("OWNER")
  city            String?
  region          String?
  ipHash          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sessions                Session[]
  authTokens              AuthToken[]
  stores                  Store[]
  acquisitionAttributions AcquisitionAttribution[]
  partnerPortal           Partner?
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AuthToken {
  id        String        @id @default(cuid())
  userId    String
  type      AuthTokenType
  tokenHash String        @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([expiresAt])
}

model Store {
  id                            String    @id @default(cuid())
  ownerId                       String
  name                          String
  slug                          String    @unique
  description                   String?
  commercialTagline             String?
  whatsapp                      String
  instagram                     String?
  tiktok                        String?
  logoUrl                       String?
  coverUrl                      String?
  countryCode                   String?   @default("BO")
  countryName                   String?
  currency                      String?   @default("BOB")
  locale                        String?
  timezone                      String?
  city                          String?
  region                        String?
  themeColor                    String    @default("#128C4A")
  brandPrimaryColor             String?   @default("#128C4A")
  brandBackgroundColor          String?   @default("#FAF7EF")
  brandAccentColor              String?   @default("#A3E635")
  brandThemePreset              String?   @default("JAKAWI")
  commercialTemplate            String?   @default("SHOWCASE")
  isPublished                   Boolean   @default(true)
  plan                          String    @default("LAUNCH")
  planStatus                    String    @default("ACTIVE")
  planStartedAt                 DateTime?
  trialEndsAt                   DateTime?
  planRenewsAt                  DateTime?
  sellerAiPeriodStart           DateTime?
  sellerAiConversationCount     Int       @default(0)
  sellerVoiceEnabled            Boolean   @default(true)
  sellerVoiceDisplayName        String?
  sellerVoiceAvatarUrl          String?
  sellerIntroAudioUrl           String?
  sellerIntroTranscript         String?
  sellerIntroDurationSeconds    Int?
  sellerIntroEnabled            Boolean   @default(true)
  sellerGuidanceAudioUrl        String?
  sellerGuidanceTranscript      String?
  sellerGuidanceDurationSeconds Int?
  sellerGuidanceEnabled         Boolean   @default(true)
  sellerHandoffAudioUrl         String?
  sellerHandoffTranscript       String?
  sellerHandoffDurationSeconds  Int?
  sellerHandoffEnabled          Boolean   @default(true)
  commercialType                String?   @default("PRODUCT_STORE")
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt

  owner                     User                     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  products                  Product[]
  categories                Category[]
  events                    AnalyticsEvent[]
  leads                     Lead[]
  journeys                  CustomerJourney[]
  acquisitionAttribution    AcquisitionAttribution?  @relation("AcquiredStore")
  referredStoreAttributions AcquisitionAttribution[] @relation("StoreReferrer")
  partnerCommissions        PartnerCommission[]
  payments                  StorePayment[]
  referralRewardsEarned     StoreReferralReward[]    @relation("ReferralRewardReferrer")
  referralRewardsGenerated  StoreReferralReward[]    @relation("ReferralRewardReferred")
  referralGrowthClicks      GrowthLinkClick[]        @relation("GrowthClickReferrerStore")

  @@index([ownerId])
  @@index([slug])
}

model Partner {
  id                String   @id @default(cuid())
  name              String
  code              String   @unique
  contactName       String?
  contactEmail      String?
  contactPhone      String?
  portalUserId      String?  @unique
  status            String   @default("ACTIVE")
  commissionRateBps Int      @default(2000)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  attributions AcquisitionAttribution[]
  destinations PartnerDestination[]
  commissions  PartnerCommission[]
  growthClicks GrowthLinkClick[]
  portalUser   User?                    @relation(fields: [portalUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt])
}

model PartnerDestination {
  id        String   @id @default(cuid())
  partnerId String
  label     String
  slug      String
  targetUrl String
  status    String   @default("ACTIVE")
  isDefault Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  partner      Partner                  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  attributions AcquisitionAttribution[]
  growthClicks GrowthLinkClick[]

  @@unique([partnerId, slug])
  @@index([partnerId])
  @@index([status])
  @@index([partnerId, isDefault])
  @@index([createdAt])
}

model AcquisitionAttribution {
  id                     String    @id @default(cuid())
  storeId                String    @unique
  userId                 String?
  sourceType             String
  status                 String    @default("SIGNED_UP")
  referrerStoreId        String?
  partnerId              String?
  partnerDestinationId   String?
  partnerDestinationSlug String?
  code                   String?
  landingPath            String?
  notes                  String?
  firstSeenAt            DateTime?
  signedUpAt             DateTime  @default(now())
  activatedAt            DateTime?
  paidAt                 DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  store                Store                 @relation("AcquiredStore", fields: [storeId], references: [id], onDelete: Cascade)
  referrerStore        Store?                @relation("StoreReferrer", fields: [referrerStoreId], references: [id], onDelete: SetNull)
  partner              Partner?              @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  partnerDestination   PartnerDestination?   @relation(fields: [partnerDestinationId], references: [id], onDelete: SetNull)
  user                 User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  partnerCommissions   PartnerCommission[]
  storeReferralRewards StoreReferralReward[]

  @@index([sourceType])
  @@index([status])
  @@index([referrerStoreId])
  @@index([partnerId])
  @@index([partnerDestinationId])
  @@index([partnerDestinationSlug])
  @@index([userId])
  @@index([code])
  @@index([createdAt])
}

model GrowthLinkClick {
  id String @id @default(cuid())

  sourceType String

  partnerId String?
  partner   Partner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)

  partnerDestinationId String?
  partnerDestination   PartnerDestination? @relation(fields: [partnerDestinationId], references: [id], onDelete: SetNull)

  referrerStoreId String?
  referrerStore   Store?  @relation("GrowthClickReferrerStore", fields: [referrerStoreId], references: [id], onDelete: SetNull)

  code            String?
  destinationSlug String?
  landingPath     String
  targetUrl       String?
  referrer        String?
  userAgent       String?
  ipHash          String?
  visitorId       String?
  clickedAt       DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([sourceType])
  @@index([partnerId])
  @@index([partnerDestinationId])
  @@index([referrerStoreId])
  @@index([code])
  @@index([destinationSlug])
  @@index([clickedAt])
  @@index([sourceType, clickedAt])
  @@index([partnerId, clickedAt])
  @@index([referrerStoreId, clickedAt])
}

model StoreReferralReward {
  id String @id @default(cuid())

  referrerStoreId String
  referrerStore   Store  @relation("ReferralRewardReferrer", fields: [referrerStoreId], references: [id], onDelete: Cascade)

  referredStoreId String?
  referredStore   Store?  @relation("ReferralRewardReferred", fields: [referredStoreId], references: [id], onDelete: SetNull)

  attributionId String?
  attribution   AcquisitionAttribution? @relation(fields: [attributionId], references: [id], onDelete: SetNull)

  rewardType       String
  valueLabel       String?
  valueAmountCents Int?
  currency         String?
  sellerAiCredits  Int?
  months           Int?

  status               String  @default("PENDING")
  description          String?
  notes                String?
  applicationReference String?

  earnedAt    DateTime?
  approvedAt  DateTime?
  appliedAt   DateTime?
  cancelledAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdByUserId   String?
  approvedByUserId  String?
  appliedByUserId   String?
  cancelledByUserId String?

  @@index([referrerStoreId])
  @@index([referredStoreId])
  @@index([attributionId])
  @@index([rewardType])
  @@index([status])
  @@index([createdAt])
  @@index([appliedAt])
}

model PartnerCommission {
  id String @id @default(cuid())

  partnerId     String
  partner       Partner                 @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  storeId       String?
  store         Store?                  @relation(fields: [storeId], references: [id], onDelete: SetNull)
  attributionId String?
  attribution   AcquisitionAttribution? @relation(fields: [attributionId], references: [id], onDelete: SetNull)

  currency              String @default("BOB")
  basisAmountCents      Int?
  commissionAmountCents Int
  commissionRateBps     Int?

  status           String  @default("PENDING")
  description      String?
  notes            String?
  paymentReference String?

  earnedAt    DateTime?
  approvedAt  DateTime?
  paidAt      DateTime?
  cancelledAt DateTime?
  reversedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdByUserId   String?
  approvedByUserId  String?
  paidByUserId      String?
  cancelledByUserId String?
  reversedByUserId  String?

  @@index([partnerId])
  @@index([storeId])
  @@index([attributionId])
  @@index([status])
  @@index([createdAt])
  @@index([paidAt])
}

model StorePayment {
  id String @id @default(cuid())

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  planKey     String?
  paymentType String

  amountCents Int
  currency    String @default("BOB")

  status String @default("PENDING")

  paymentMethod     String?
  externalReference String?
  description       String?
  notes             String?

  periodStart DateTime?
  periodEnd   DateTime?

  paidAt      DateTime?
  confirmedAt DateTime?
  cancelledAt DateTime?
  refundedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdByUserId   String?
  confirmedByUserId String?
  cancelledByUserId String?
  refundedByUserId  String?

  @@index([storeId])
  @@index([status])
  @@index([planKey])
  @@index([paymentType])
  @@index([paidAt])
  @@index([confirmedAt])
  @@index([createdAt])
  @@index([storeId, createdAt])
  @@index([status, createdAt])
}

model Category {
  id        String   @id @default(cuid())
  storeId   String
  name      String
  slug      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store         Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products      Product[]
  journeys      CustomerJourney[]
  journeyEvents JourneyEvent[]

  @@unique([storeId, slug])
  @@index([storeId])
}

model Product {
  id          String    @id @default(cuid())
  storeId     String
  categoryId  String?
  name        String
  slug        String
  description String?
  priceCents  Int
  currency    String    @default("BOB")
  imageUrl    String?
  isVisible   Boolean   @default(true)
  isFeatured  Boolean   @default(false)
  featuredAt  DateTime?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  store           Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category        Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  events          AnalyticsEvent[]
  currentJourneys CustomerJourney[] @relation("JourneyCurrentProduct")
  journeyEvents   JourneyEvent[]

  @@unique([storeId, slug])
  @@index([storeId, isVisible])
  @@index([storeId, isFeatured])
  @@index([storeId, sortOrder])
  @@index([categoryId])
  @@index([createdAt])
}

model AnalyticsEvent {
  id        String             @id @default(cuid())
  storeId   String
  productId String?
  type      AnalyticsEventType
  ipHash    String?
  userAgent String?
  metadata  Json?
  createdAt DateTime           @default(now())

  store   Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([storeId, createdAt])
  @@index([productId, createdAt])
  @@index([type, createdAt])
}

model Lead {
  id                  String     @id @default(cuid())
  leadCode            String     @unique
  storeId             String
  sessionId           String
  visitorId           String?
  journeyId           String?
  snapshotId          String?
  customerName        String?
  customerPhone       String?
  source              String?
  status              LeadStatus @default(BROWSING)
  intentScore         Int        @default(10)
  currentProductId    String?
  selectedProductId   String?
  selectedVariant     String?
  city                String?
  budget              String?
  urgency             String?
  objections          String[]   @default([])
  conversationSummary String?
  whatsappMessage     String?
  whatsappClickedAt   DateTime?
  lastActivityAt      DateTime?
  viewedProducts      Json?
  recommendedProducts Json?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  store          Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  journey        CustomerJourney?     @relation(fields: [journeyId], references: [id], onDelete: SetNull)
  activeSnapshot CommercialSnapshot?  @relation("LeadActiveSnapshot", fields: [snapshotId], references: [id], onDelete: SetNull)
  snapshots      CommercialSnapshot[] @relation("LeadSnapshots")
  conversation   Conversation?
  events         LeadEvent[]

  @@index([storeId, createdAt])
  @@index([storeId, lastActivityAt])
  @@index([sessionId])
  @@index([visitorId])
  @@index([journeyId])
  @@index([snapshotId])
  @@index([status])
  @@index([intentScore])
}

model CustomerJourney {
  id          String                @id @default(cuid())
  journeyCode String                @unique
  storeId     String
  sessionId   String
  visitorId   String?
  source      String?
  status      CustomerJourneyStatus @default(ACTIVE)
  stage       CustomerJourneyStage  @default(DISCOVERY)

  currentProductId  String?
  currentCategoryId String?

  detectedNeed        String?
  budget              String?
  urgency             String?
  objections          String?
  conversationSummary String?
  sellerAiCountedAt   DateTime?

  intentScore Int @default(0)

  customerName  String?
  customerPhone String?
  city          String?

  viewedProducts      Json?
  recommendedProducts Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store           Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  currentProduct  Product?  @relation("JourneyCurrentProduct", fields: [currentProductId], references: [id], onDelete: SetNull)
  currentCategory Category? @relation(fields: [currentCategoryId], references: [id], onDelete: SetNull)

  events    JourneyEvent[]
  snapshots CommercialSnapshot[]
  leads     Lead[]

  @@index([storeId])
  @@index([sessionId])
  @@index([visitorId])
  @@index([status])
  @@index([stage])
  @@index([createdAt])
}

model JourneyEvent {
  id         String           @id @default(cuid())
  journeyId  String
  type       JourneyEventType
  productId  String?
  categoryId String?
  payload    Json?
  createdAt  DateTime         @default(now())

  journey  CustomerJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  product  Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  category Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([journeyId])
  @@index([type])
  @@index([createdAt])
}

model CommercialSnapshot {
  id           String @id @default(cuid())
  snapshotCode String @unique

  journeyId String
  leadId    String?

  channel CommercialSnapshotChannel @default(WHATSAPP)

  customerSummary  String?
  detectedNeed     String?
  currentItem      Json?
  recommendedItems Json?
  viewedItems      Json?
  objections       String?
  budget           String?
  urgency          String?
  intentScore      Int     @default(0)

  customerName  String?
  customerPhone String?
  city          String?

  channelMessage  String?
  whatsappMessage String?

  createdAt DateTime @default(now())

  journey         CustomerJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  lead            Lead?           @relation("LeadSnapshots", fields: [leadId], references: [id], onDelete: SetNull)
  selectedByLeads Lead[]          @relation("LeadActiveSnapshot")

  @@index([journeyId])
  @@index([leadId])
  @@index([channel])
  @@index([createdAt])
}

model Conversation {
  id           String   @id @default(cuid())
  leadId       String   @unique
  storeId      String
  modelUsed    String?
  tokensInput  Int      @default(0)
  tokensOutput Int      @default(0)
  costEstimate Decimal? @db.Decimal(10, 6)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lead     Lead                  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  messages ConversationMessage[]

  @@index([leadId])
  @@index([storeId, createdAt])
}

model ConversationMessage {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  metadata       Json?
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model LeadEvent {
  id        String        @id @default(cuid())
  leadId    String?
  sessionId String
  storeId   String
  eventType LeadEventType
  productId String?
  metadata  Json?
  createdAt DateTime      @default(now())

  lead Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([storeId, createdAt])
  @@index([sessionId])
  @@index([leadId])
  @@index([eventType])
}
